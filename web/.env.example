NEXT_PUBLIC_SITE_URL=http://localhost:3000
CONVEX_DEPLOYMENT=shocking-dogfish-273
NEXT_PUBLIC_CONVEX_URL=https://<shared-production-deployment>.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://<shared-production-deployment>.convex.site

# SMTP used by the public contact form at /api/contact:
# SMTP_HOST=cp7231.webempresa.eu
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=info@bauset.es
# SMTP_PASS=<smtp password>
# CONTACT_FROM_EMAIL=Portal Arduino <info@bauset.es>

# Set these in Convex with `npx convex env set`, not only in .env.local:
# SITE_URL=https://arduino-bauset.vercel.app
# AUTH_ALLOWED_HOSTS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000,arduino-bauset.vercel.app
# AUTH_TRUSTED_ORIGINS=http://localhost:3000,https://arduino-bauset.vercel.app
# BETTER_AUTH_SECRET=<generated secret>
# GOOGLE_CLIENT_ID=<google oauth client id>
# GOOGLE_CLIENT_SECRET=<google oauth client secret>
# SETUP_TEACHER_SECRET=<one-time teacher setup secret>
# SEED_SECRET=<worksheet seed secret>
